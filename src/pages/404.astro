---
import Layout from '../layouts/Layout.astro';
import { NAV_PRIMARY } from '../data/site';
const title = '404 – Seite nicht gefunden | NoFreeze IPTV';
const description = 'Diese Seite wurde nicht gefunden. Kehren Sie zur Startseite zurück oder entdecken Sie unsere IPTV-Pakete, Geräte und Länder.';
---
<Layout title={title} description={description} noindex={true}>
  <section class="section center" style="padding-top:4rem;">
    <div class="container" style="max-width:42rem;">
      <p class="eyebrow">Fehler 404</p>
      <h1>Diese Seite gibt es leider nicht</h1>
      <p class="lead center">Die gesuchte Seite wurde verschoben oder existiert nicht mehr. Nutzen Sie die Links unten,
        um weiterzustöbern.</p>
      <div class="mt-3" style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a class="btn btn--primary btn--lg" href="/">Zur Startseite</a>
        <a class="btn btn--outline btn--lg" href="/iptv-subscription-plans/">Preise ansehen</a>
      </div>
      <div class="tag-cloud mt-4" style="justify-content:center;">
        {NAV_PRIMARY.map((n) => (<a class="tag" href={n.path}>{n.label}</a>))}
      </div>
    </div>
  </section>
</Layout>
